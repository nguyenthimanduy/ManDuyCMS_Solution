@model IEnumerable<CMS.Data.Entities.CategoriesProduct>

@{
    ViewData["Title"] = "Danh mục sản phẩm";
}


<div class="animate-fade-in">


    <div class="page-header">

        <div>

            <h2>Danh mục sản phẩm</h2>

            <div class="subtitle">
                Quản lý phân loại sản phẩm trong hệ thống
            </div>

        </div>


        <a asp-action="Create"
           class="btn-cyber btn-cyber-success">

            <i class="fa-solid fa-plus"></i>

            Thêm mới

        </a>


    </div>





    <div class="cyber-table-wrapper">


        <table class="cyber-table">


            <thead>


                <tr>


                    <th class="text-center">
                        ID
                    </th>


                    <th class="text-center">
                        Hình ảnh
                    </th>


                    <th>
                        Tên danh mục
                    </th>


                    <th>
                        Mô tả
                    </th>


                    <th class="text-center">
                        Hành động
                    </th>


                </tr>


            </thead>





            <tbody>



                @if (!Model.Any())
                {

                    <tr class="empty-row">

                        <td colspan="5"
                            class="text-center">

                            Chưa có danh mục sản phẩm nào.

                        </td>

                    </tr>


                }
                else
                {


                    foreach (var item in Model)
                    {


                        <tr>


                            <td class="text-center">

                                @item.Id

                            </td>





                            <!-- ẢNH -->

                            <td class="text-center">


                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {


                                    <img src="@item.ImageUrl"
                                         alt="@item.Name"
                                         class="category-image" />


                                }
                                else
                                {


                                    <i class="fa-regular fa-image fa-2x text-secondary"></i>


                                }



                            </td>







                            <td>


                                <b>
                                    @item.Name
                                </b>


                            </td>






                            <td>

                                @(item.Description ?? "Không có mô tả")

                            </td>







                            <td class="text-center">


                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn-cyber btn-cyber-primary btn-cyber-sm">


                                    <i class="fa-solid fa-pen"></i>

                                    Sửa


                                </a>





                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn-cyber btn-cyber-danger btn-cyber-sm">


                                    <i class="fa-solid fa-trash"></i>

                                    Xóa


                                </a>


                            </td>


                        </tr>


                    }


                }



            </tbody>


        </table>


    </div>



</div>