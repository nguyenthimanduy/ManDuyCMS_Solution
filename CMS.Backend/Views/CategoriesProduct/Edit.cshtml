@model CMS.Data.Entities.CategoriesProduct

@{
    ViewData["Title"] = "Sửa danh mục sản phẩm";
}

<div class="animate-fade-in">
    <div class="page-header">
        <div>
            <h2>Sửa danh mục SP</h2>
            <div class="subtitle">Cập nhật thông tin danh mục sản phẩm</div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="cyber-form-container">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ImageUrl" />

                    <div class="cyber-form-group">
                        <label class="cyber-label">Tên danh mục</label>
                        <input asp-for="Name" class="cyber-input" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="cyber-form-group">
                        <label class="cyber-label">Mô tả danh mục</label>
                        <textarea asp-for="Description" class="cyber-input" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="cyber-form-group">
                        <label class="cyber-label">Hình ảnh hiện tại</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div style="margin-bottom: 12px;">
                                <img src="@Model.ImageUrl" alt="Hình ảnh danh mục" style="max-height: 120px; border-radius: 8px; border: 1px solid var(--border-color, #2a2f3a);" />
                            </div>
                        }
                        else
                        {
                            <p style="color: var(--text-muted); font-size: 0.9rem;">Chưa có hình ảnh</p>
                        }
                        <input type="file" name="ImageFile" accept="image/*" class="cyber-input" />
                    </div>

                    <div class="cyber-form-actions">
                        <button type="submit" class="btn-cyber btn-cyber-filled-primary">
                            <i class="fa-solid fa-floppy-disk"></i> Cập nhật
                        </button>
                        <a asp-action="Index" class="btn-cyber btn-cyber-secondary">
                            <i class="fa-solid fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
