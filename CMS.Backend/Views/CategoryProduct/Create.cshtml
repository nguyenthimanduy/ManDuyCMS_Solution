@model CMS.Data.Entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm danh mục sản phẩm";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-folder-plus"></i> THÊM DANH MỤC SẢN PHẨM MỚI</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên danh mục sản phẩm:</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục (ví dụ: Điện thoại, Laptop...)" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả danh mục:</label>
                    <textarea asp-for="Description" class="form-control" rows="6" placeholder="Nhập mô tả ngắn gọn về danh mục sản phẩm..."></textarea>
                </div>

                <hr />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Lưu danh mục
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>