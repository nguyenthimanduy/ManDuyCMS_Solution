@model CMS.Data.Entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="card shadow-sm border-0 rounded-3 m-4">
    <div class="card-header bg-white py-3">
        <h5 class="text-dark fw-bold mb-0">
            <i class="bi bi-pencil-square text-warning me-2"></i>CHỈNH SỬA DANH MỤC SẢN PHẨM
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Tên danh mục sản phẩm</label>
                <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." required />
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold">Mô tả danh mục</label>
                <textarea asp-for="Description" class="form-control" rows="6" placeholder="Nhập mô tả cụ thể..." required></textarea>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-bold">
                    <i class="bi bi-save me-1"></i> Cập nhật danh mục
                </button>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>