@model IEnumerable<CMS.Data.Entities.CategoryProduct>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý danh mục sản phẩm";
}
<div class="container mt-4">
    <h2 class="mb-4 text-danger">DANH MỤC SẢN PHẨM HIỆN CÓ</h2>
    <a asp-action="Create" class="btn btn-success mb-3">
        <i class="bi bi-plus-circle"></i> Thêm danh mục mới
    </a>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="text-center bg-light py-4 border-bottom text-warning">
                        <i class="bi bi-folder-fill" style="font-size: 4rem;"></i>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-info text-dark align-self-start mb-2">Mã DM: #@item.Id</span>
                        <h5 class="card-title text-primary fw-bold">@item.Name</h5>

                        <p class="card-text text-truncate text-secondary flex-grow-1" style="max-width: 100%;">
                            @item.Description
                        </p>

                        <div class="mt-3 pt-2 border-top gap-1 d-flex justify-content-between">
                            <a href="/CategoryProduct/Details/@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                Sửa
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này? Toàn bộ sản phẩm thuộc danh mục này có thể bị ảnh hưởng.')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>