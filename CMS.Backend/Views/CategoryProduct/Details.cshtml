@model CMS.Data.Entities.CategoryProduct
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/CategoryProduct" class="text-decoration-none">Danh mục sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết danh mục</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <h1 class="display-4 fw-bold text-primary mb-3">@Model.Name</h1>

            <div class="d-flex align-items-center gap-3 text-muted mb-4">
                <span class="badge bg-info text-dark fs-6">Mã danh mục: #@Model.Id</span>
            </div>

            <hr />

            <div class="text-center mb-4 bg-light p-4 rounded shadow-sm border">
                <i class="bi bi-folder2-open text-warning" style="font-size: 5rem;"></i>
                <h4 class="mt-2 text-dark fw-bold">THÔNG TIN CHI TIẾT DANH MỤC</h4>
            </div>

            <div class="fs-5 text-secondary lh-lg mb-5">
                <p class="fw-bold text-dark mb-1"><i class="bi bi-file-text text-primary"></i> Mô tả danh mục:</p>
                <div class="p-3 bg-white border rounded">
                    @Model.Description
                </div>
            </div>

            <div class="mt-5 border-top pt-4 d-flex gap-2">
                <a href="/CategoryProduct" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Chỉnh sửa danh mục
                </a>
            </div>
        </div>
    </div>
</div>