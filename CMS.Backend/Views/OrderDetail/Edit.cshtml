@model CMS.Data.Entities.OrderDetail

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa mục đơn hàng";
}

<div class="card shadow-sm border-0 rounded-3 m-4">
    <div class="card-header bg-white py-3">
        <h5 class="text-dark fw-bold mb-0">
            <i class="bi bi-pencil-square text-warning me-2"></i>CHỈNH SỬA CHI TIẾT MỤC ĐƠN HÀNG
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Mã Đơn Hàng</label>
                    <select asp-for="OrderId" class="form-select" asp-items="ViewBag.OrderList" required></select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Sản phẩm</label>
                    <select asp-for="ProductId" class="form-select" asp-items="ViewBag.ProductList" required></select>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Quantity" class="form-label fw-bold">Số lượng</label>
                    <input asp-for="Quantity" type="number" class="form-control" min="1" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="UnitPrice" class="form-label fw-bold">Đơn giá (VNĐ)</label>
                    <input asp-for="UnitPrice" type="number" class="form-control" min="0" required />
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-bold">
                    <i class="bi bi-save me-1"></i> Cập nhật mục
                </button>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>