@model CMS.Data.Entities.OrderDetail
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết mục đơn hàng";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/OrderDetail" class="text-decoration-none">Chi tiết đơn hàng</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết mục</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1 class="display-6 fw-bold text-primary mb-3">Mục Đơn Hàng #@Model.Id</h1>

            <hr />

            <div class="bg-light p-4 rounded shadow-sm border mb-4">
                <table class="table table-borderless mb-0 fs-5">
                    <tr>
                        <td class="fw-bold" style="width: 40%;"><i class="bi bi-receipt text-primary"></i> Mã đơn hàng chính:</td>
                        <td>#@Model.OrderId</td>
                    </tr>
                    <tr>
                        <td class="fw-bold"><i class="bi bi-cart4 text-success"></i> Sản phẩm:</td>
                        <td>@(Model.Product != null ? Model.Product.Name : "N/A")</td>
                    </tr>
                    <tr>
                        <td class="fw-bold"><i class="bi bi-calculator text-info"></i> Số lượng:</td>
                        <td>@Model.Quantity</td>
                    </tr>
                    <tr>
                        <td class="fw-bold"><i class="bi bi-currency-dollar text-warning"></i> Đơn giá:</td>
                        <td>@Model.UnitPrice.ToString("N0") VNĐ</td>
                    </tr>
                    <tr class="table-warning border-top">
                        <td class="fw-bold text-danger"><i class="bi bi-cash-coin"></i> Thành tiền:</td>
                        <td class="fw-bold text-danger">@((Model.Quantity * Model.UnitPrice).ToString("N0")) VNĐ</td>
                    </tr>
                </table>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a href="/OrderDetail" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Chỉnh sửa thông tin
                </a>
            </div>
        </div>
    </div>
</div>