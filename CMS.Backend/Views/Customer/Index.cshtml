@model IEnumerable<CMS.Data.Entities.Customer>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý khách hàng";
}
<div class="container mt-4">
    <h2 class="mb-4 text-danger">DANH SÁCH KHÁCH HÀNG MỚI NHẤT</h2>
    <a asp-action="Create" class="btn btn-success mb-3">
        <i class="bi bi-plus-circle"></i> Thêm khách hàng mới
    </a>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="text-center bg-light py-4 border-bottom">
                        <i class="bi bi-person-circle text-primary" style="font-size: 4.5rem;"></i>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <span class="badge bg-info text-dark align-self-start mb-2">Mã KH: #@item.Id</span>
                        <h5 class="card-title text-primary fw-bold">@item.FullName</h5>

                        <p class="card-text mb-1 text-muted small">
                            <i class="bi bi-envelope"></i> @item.Email
                        </p>
                        <p class="card-text mb-2 text-muted small">
                            <i class="bi bi-telephone"></i> @item.Phone
                        </p>
                        <p class="card-text text-truncate text-secondary flex-grow-1" style="max-width: 100%;">
                            <i class="bi bi-geo-alt"></i> @item.Address
                        </p>

                        <div class="mt-3 pt-2 border-top gap-1 d-flex justify-content-between">
                            <a href="/Customer/Details/@item.Id" class="btn btn-outline-primary btn-sm">Chi tiết</a>

                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                Sửa
                            </a>

                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa khách hàng này không?')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>