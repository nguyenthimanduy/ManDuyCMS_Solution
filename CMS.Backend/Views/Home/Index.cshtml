@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">

    <!-- Header -->
    <div class="text-center mb-5">

        <h1 class="display-4 fw-bold text-primary">
            CMS MANAGEMENT SYSTEM
        </h1>

        <p class="lead text-muted">
            Build and manage your website with ASP.NET Core MVC
        </p>

    </div>

    <!-- Content -->
    <div class="row">

        <!-- Post -->
        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h3 class="text-danger">
                        POST MANAGEMENT
                    </h3>

                    <p class="text-muted">
                        Manage articles, blog posts and website content.
                    </p>

                    <a href="/Post"
                       class="btn btn-danger">

                        View Posts
                    </a>

                </div>

            </div>

        </div>

        <!-- User -->
        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h3 class="text-success">
                        USER MANAGEMENT
                    </h3>

                    <p class="text-muted">
                        Manage administrators, editors and authors.
                    </p>

                    <a href="/User"
                       class="btn btn-success">

                        View Users
                    </a>

                </div>

            </div>

        </div>

        <!-- Category -->
        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <div class="card-body text-center">

                    <h3 class="text-primary">
                        CATEGORY MANAGEMENT
                    </h3>

                    <p class="text-muted">
                        Manage categories and organize website content.
                    </p>

                    <a href="/Category"
                       class="btn btn-primary">

                        View Categories
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

