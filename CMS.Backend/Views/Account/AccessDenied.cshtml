@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="animate-fade-in">
    <div style="text-align: center; padding: 60px 20px;">
        <div style="font-size: 5rem; margin-bottom: 20px;">
            <i class="fa-solid fa-ban" style="color: var(--neon-magenta); text-shadow: 0 0 30px rgba(255,45,123,0.5);"></i>
        </div>
        <h1 style="font-family: 'Orbitron', sans-serif; font-size: 2rem; color: var(--neon-magenta); text-shadow: 0 0 15px rgba(255,45,123,0.4); letter-spacing: 4px; margin-bottom: 16px;">
            TRUY CẬP BỊ TỪ CHỐI
        </h1>
        <p style="color: var(--text-secondary); font-size: 1rem; max-width: 500px; margin: 0 auto 32px;">
            Bạn không có quyền truy cập vào trang này. 
            Vui lòng liên hệ Quản trị viên nếu cần được cấp quyền.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
            <a asp-controller="Home" asp-action="Index" class="btn-cyber btn-cyber-primary">
                <i class="fa-solid fa-house"></i> Về Dashboard
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn-cyber btn-cyber-secondary">
                <i class="fa-solid fa-right-to-bracket"></i> Đăng nhập lại
            </a>
        </div>

        <div class="cyber-card" style="max-width: 400px; margin: 40px auto 0; text-align: left;">
            <div class="card-header-cyber">
                <i class="fa-solid fa-circle-info"></i> Thông tin tài khoản
            </div>
            <dl class="cyber-dl" style="grid-template-columns: 120px 1fr;">
                <dt>Tài khoản</dt>
                <dd><b>@User.Identity?.Name</b></dd>
                <dt>Vai trò</dt>
                <dd>
                    @if (User.IsInRole("Admin"))
                    {
                        <span class="badge-cyber badge-cyber-danger">Admin</span>
                    }
                    else if (User.IsInRole("Editor"))
                    {
                        <span class="badge-cyber badge-cyber-info">Editor</span>
                    }
                    else
                    {
                        <span class="badge-cyber badge-cyber-secondary">Chưa xác định</span>
                    }
                </dd>
            </dl>
        </div>
    </div>
</div>
