@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa sản phẩm";
}

<div class="card shadow-sm border-0 rounded-3 m-4">
    <div class="card-header bg-white py-3">
        <h5 class="text-dark fw-bold mb-0">
            <i class="bi bi-pencil-square text-warning me-2"></i>CHỈNH SỬA THÔNG TIN SẢN PHẨM
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                    <input asp-for="Name" class="form-control" required />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="CategoryProductId" class="form-label fw-bold">Danh mục thuộc về</label>
                    <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryList" required></select>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Price" class="form-label fw-bold">Giá sản phẩm (VNĐ)</label>
                    <input asp-for="Price" type="number" class="form-control" required />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Thay ảnh mới</label>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                </div>

                <div class="col-md-4 mb-3 text-center">
                    <label class="form-label fw-bold d-block">Ảnh hiện tại</label>
                    <img src="@Model.ImageUrl" class="img-thumbnail" style="max-height: 100px; object-fit: contain;" />
                </div>

                <div class="col-12 mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" class="form-control" rows="8"></textarea>
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-bold">
                    <i class="bi bi-save me-1"></i> Cập nhật sản phẩm
                </button>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        ClassicEditor
            .create(document.querySelector('#Description'))
            .catch(error => { console.error(error); });
    </script>
}