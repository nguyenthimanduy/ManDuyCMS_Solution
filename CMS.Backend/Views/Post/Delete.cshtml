@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Xóa bài viết";
}

<div class="animate-fade-in">
    <div class="page-header">
        <div>
            <h2 style="color: var(--neon-magenta); text-shadow: 0 0 12px rgba(255,45,123,0.4);">Xóa bài viết</h2>
            <div class="subtitle">Xác nhận xóa bài viết khỏi hệ thống</div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="cyber-alert cyber-alert-danger">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <div>
                    <strong>Cảnh báo!</strong> Bạn có chắc chắn muốn xóa bài viết này không? Hành động này không thể hoàn tác!
                </div>
            </div>

            <div class="cyber-card">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="delete-image-preview">
                        <img src="@Model.ImageUrl" alt="@Model.Title" />
                    </div>
                }

                <dl class="cyber-dl">
                    <dt>Tiêu đề</dt>
                    <dd><b>@Model.Title</b></dd>
                    <dt>Chuyên mục</dt>
                    <dd><span class="badge-cyber badge-cyber-purple">@Model.Category?.Name</span></dd>
                    <dt>Ngày đăng</dt>
                    <dd>@Model.CreatedDate.ToString("dd/MM/yyyy")</dd>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <dt>Ảnh</dt>
                        <dd><span class="badge-cyber badge-cyber-info">Có ảnh đính kèm</span></dd>
                    }
                </dl>
            </div>

            <div class="cyber-form-actions">
                <form asp-action="Delete" method="post" style="display: inline;">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn-cyber btn-cyber-filled-danger">
                        <i class="fa-solid fa-trash"></i> Xác nhận xóa
                    </button>
                </form>
                <a asp-action="Index" class="btn-cyber btn-cyber-secondary">
                    <i class="fa-solid fa-arrow-left"></i> Hủy
                </a>
            </div>
        </div>
    </div>
</div>