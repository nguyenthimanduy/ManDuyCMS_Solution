@model CMS.Data.Entities.Post
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Post" class="text-decoration-none">Danh sách bài viết</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết bài viết</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <h1 class="display-4 fw-bold text-primary mb-3">@Model.Title</h1>

            <div class="d-flex align-items-center gap-3 text-muted mb-4">
                @if (Model.Category != null)
                {
                    <span class="badge bg-info text-dark fs-6">@Model.Category.Name</span>
                }
                <span><i class="bi bi-calendar3"></i> Đăng ngày: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>

            <hr />

            <div class="text-center mb-4">
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Title" style="width: 100%; max-height: 450px; object-fit: cover;">
            </div>

            <div class="post-content fs-5 text-secondary lh-lg mb-5">
                @Html.Raw(Model.Content)
            </div>

            <div class="mt-5 border-top pt-4 d-flex gap-2">
                <a href="/Post" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại danh sách
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                    <i class="bi bi-pencil-square"></i> Chỉnh sửa bài viết
                </a>
            </div>
        </div>
    </div>
</div>