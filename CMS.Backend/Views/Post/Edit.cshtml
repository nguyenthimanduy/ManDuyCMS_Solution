@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-header bg-white py-3">
        <h5 class="text-dark fw-bold mb-0">
            <i class="bi bi-pencil-square text-warning me-2"></i>CHỈNH SỬA BÀI VIẾT
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Id" />

            <input type="hidden" asp-for="ImageUrl" />
            <input type="hidden" asp-for="CreatedDate" />

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="CategoryId" class="form-label fw-bold">Chuyên mục bài viết</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                        <option value="">-- Chọn chuyên mục --</option>
                    </select>
                </div>

                <div class="col-12 mb-3">
                    <label asp-for="Content" class="form-label fw-bold">Nội dung bài viết</label>
                    <textarea asp-for="Content" class="form-control" rows="6" placeholder="Nhập nội dung chi tiết bài viết..." required></textarea>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold">Hình ảnh đại diện bài viết</label>
                    <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                    <small class="text-muted d-block mt-1">Để trống nếu muốn giữ nguyên ảnh cũ.</small>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-bold d-block">Ảnh hiện tại</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="Current Thumbnail" class="img-thumbnail" style="max-height: 120px; object-fit: cover;" />
                    }
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-bold">
                    <i class="bi bi-save me-1"></i> Cập nhật bài viết
                </button>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>