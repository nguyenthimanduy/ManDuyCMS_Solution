@model CMS.Data.Entities.Order

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Cập nhật đơn hàng";
}

<div class="card shadow-sm border-0 rounded-3 m-4">
    <div class="card-header bg-white py-3">
        <h5 class="text-dark fw-bold mb-0">
            <i class="bi bi-pencil-square text-warning me-2"></i>CẬP NHẬT TRẠNG THÁI & ĐƠN HÀNG
        </h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="OrderDate" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Khách hàng đặt hàng</label>
                    <select asp-for="CustomerId" class="form-select" asp-items="ViewBag.CustomerList" required></select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Cập nhật trạng thái xử lý</label>
                    <select asp-for="Status" class="form-select" required>
                        <option value="0">Chờ xử lý (Mới nhận)</option>
                        <option value="1">Đang giao hàng</option>
                        <option value="2">Đã hoàn thành</option>
                        <option value="3">Đã hủy đơn</option>
                    </select>
                </div>

                <div class="col-12 mb-3">
                    <label asp-for="Notes" class="form-label fw-bold">Sửa đổi ghi chú</label>
                    <textarea asp-for="Notes" class="form-control" rows="5" placeholder="Nhập ghi chú..."></textarea>
                </div>
            </div>

            <hr />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning px-4 fw-bold">
                    <i class="bi bi-save me-1"></i> Lưu thay đổi
                </button>
                <a asp-action="Index" class="btn btn-secondary px-4">
                    Quay lại danh sách
                </a>
            </div>
        </form>
    </div>
</div>